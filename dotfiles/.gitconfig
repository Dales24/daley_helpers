# Mock .gitconfig — replace name/email before use.
[user]
	name = Your Name
	email = you@example.com

[init]
	defaultBranch = main

[pull]
	rebase = true

[core]
	editor = vim
	excludesfile = ~/.gitignore_global

[alias]
	co = checkout
	br = branch
	st = status
	last = log -1 HEAD
	lg = log --oneline --graph --decorate

[color]
	ui = auto
